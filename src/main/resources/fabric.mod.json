{
	"schemaVersion": 1,
	"id": "slag",
	"version": "${version}",
	"name": "Slag",
	"description": "Slag is a simple utility mod for Minecraft that aims to simplify Slang shader loading and compilation.",
	"authors": [
		"Johannes Preiser (aka. JoCraft2010)"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/JoCraft2010/Slag",
		"issues": "https://github.com/JoCraft2010/Slag/issues",
		"jocraft_github": "https://github.com/JoCraft2010"
	},
	"license": "TASL v1.0",
	"icon": "assets/slag/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.slag.Slag"
		],
		"client": [
			"com.slag.client.SlagClient"
		],
		"preLaunch": [
			"com.slag.PreLaunch"
		]
	},
	"mixins": [
		"slag.mixins.json",
		{
			"config": "slag.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": "~26.2-",
		"java": ">=25",
		"fabric-api": "*"
	}
}